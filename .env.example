# Database (Neon serverless Postgres)
# DATABASE_URL: pooled connection used by the app at runtime.
# DIRECT_URL:   direct (non-pooled) connection used for migrations.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# API-Football key (free tier: https://www.api-football.com/)
APIFOOTBALL_KEY=

# Cron ingestion auth (Vercel Cron sends this as Bearer token)
CRON_SECRET=

# Optional tuning
# LIVE_TTL=420
# IDLE_TTL=1800
# WC_LEAGUE=1
# WC_SEASON=2026
